{
  "name": "videojs-language-switch",
  "version": "2.0.0",
  "description": "Control for switching between video language versions",
  "main": "cjs/plugin.js",
  "module": "es/plugin.js",
  "browser": "dist/videojs-language-switch.js",
  "generator-videojs-plugin": {
    "version": "8.0.0"
  },
  "scripts": {
    "build": "npm-run-all -s clean -p build:*",
    "build-prod": "cross-env-shell NO_TEST_BUNDLE=1 'npm run build'",
    "build-test": "cross-env-shell TEST_BUNDLE_ONLY=1 'npm run build'",
    "build:cjs": "babel-config-cjs -d ./cjs ./src",
    "build:es": "babel-config-es -d ./es ./src",
    "build:js": "rollup -c scripts/rollup.config.js",
    "build:css": "sass --no-source-map --style=compressed src/plugin.scss dist/videojs-language-switch.css",
    "clean": "shx rm -rf ./dist ./test/dist ./cjs ./es && shx mkdir -p ./dist ./test/dist ./cjs ./es",
    "lint": "vjsstandard",
    "server": "karma start scripts/karma.conf.js --singleRun=false --auto-watch",
    "start": "npm-run-all -p server watch",
    "test": "npm-run-all lint build-test && karma start scripts/karma.conf.js",
    "posttest": "shx cat test/dist/coverage/text.txt",
    "update-changelog": "conventional-changelog -p videojs -i CHANGELOG.md -s",
    "preversion": "npm test",
    "version": "is-prerelease || npm run update-changelog && git add CHANGELOG.md",
    "watch": "npm-run-all -p watch:*",
    "watch:cjs": "npm run build:cjs -- -w",
    "watch:es": "npm run build:es -- -w",
    "watch:js": "npm run build:js -- -w",
    "prepublishOnly": "npm-run-all build-prod && vjsverify --verbose --skip-syntax"
  },
  "keywords": [
    "videojs",
    "videojs-plugin"
  ],
  "author": "Adam Oliver <mail@adamoliver.net>",
  "license": "MIT",
  "style": "dist/videojs-language-switch.css",
  "videojs-plugin": {
    "style": "dist/videojs-language-switch.css",
    "script": "dist/videojs-language-switch.min.js"
  },
  "vjsstandard": {
    "ignore": [
      "es",
      "es5",
      "cjs",
      "dist",
      "docs",
      "scripts",
      "test/dist"
    ]
  },
  "files": [
    "CONTRIBUTING.md",
    "cjs/",
    "dist/",
    "docs/",
    "es/",
    "index.html",
    "scripts/",
    "src/",
    "test/"
  ],
  "peerDependencies": {
    "video.js": "^8.0.0"
  },
  "dependencies": {
    "global": "^4.4.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.0",
    "@babel/core": "^7.22.0",
    "@babel/runtime": "^7.22.0",
    "@videojs/babel-config": "^1.0.0",
    "@videojs/generator-helpers": "~3.0.0",
    "conventional-changelog-cli": "^2.2.2",
    "conventional-changelog-videojs": "^3.0.2",
    "cross-env": "^7.0.3",
    "karma": "^6.4.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^2.79.0",
    "sass": "^1.77.0",
    "shx": "^0.3.4",
    "sinon": "^15.0.0",
    "video.js": "^8.0.0",
    "videojs-generate-karma-config": "~8.0.0",
    "videojs-generate-rollup-config": "~7.0.0",
    "videojs-generator-verify": "~4.0.0",
    "videojs-standard": "^9.0.0"
  },
  "engines": {
    "node": ">=16",
    "npm": ">=8"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "lint-staged": {
    "*.js": "vjsstandard --fix",
    "README.md": "doctoc --notitle"
  }
}